# Stripe × AdSense × Firebase Integration Environment Variables
# これらの環境変数をVercelダッシュボードで設定してください

# Firebase Configuration (Admin SDK)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Private Key Here\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_CLIENT_ID=your-client-id

# Stripe Configuration  
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_STANDARD_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Application Configuration
DOMAIN=https://your-domain.com
NODE_ENV=development

# GitHub連携設定（既存機能）
GITHUB_REPO=your-username/your-repo-name
GITHUB_TOKEN=ghp_your_github_personal_access_token

# Optional: Additional Configuration
# VERCEL_URL=your-project-name.vercel.app
# SENTRY_DSN=https://xxxxxxx@sentry.io/xxxxxxx

# 設定手順:
# 1. Vercel Dashboard → プロジェクト選択
# 2. Settings → Environment Variables
# 3. 上記変数を追加し、全環境(Production, Preview, Development)にチェック
# 4. Redeploy

# 注意事項:
# - FIREBASE_PRIVATE_KEY は改行文字を \n でエスケープしてください
# - 本番環境では sk_live_, pk_live_ のキーを使用してください
# - Webhook Secret は開発環境と本番環境で異なります
